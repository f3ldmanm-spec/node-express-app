FROM node:18-alpine

# Указываем рабочую папку
WORKDIR /app

# Копируем абсолютно всё, что скачали из гита, в образ
COPY . .

# Пробуем установить зависимости. 
# Если возникнет ошибка, мы хотя бы увидим подробности.
RUN npm install

# Запуск (убедитесь, что ваш главный файл называется index.js)
CMD ["node", "index.js"]